<h1 style="margin: 0 0 8px; font-size: 24px; font-weight: 800; color: #111827;">Welcome, <%= @user.name %>!</h1>
<p style="margin: 0 0 24px; color: #6b7280; font-size: 15px; line-height: 1.6;">
  You're one step closer to your next car. Our AI assistant will guide you through the entire process — from finding the perfect vehicle to getting it delivered to your door.
</p>

<table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 24px;">
  <tr>
    <td style="background-color: #e0f7fc; padding: 16px; border-radius: 12px; text-align: center;">
      <p style="margin: 0 0 4px; font-size: 13px; color: #0090b3; font-weight: 600;">YOUR NEXT STEP</p>
      <p style="margin: 0; font-size: 15px; color: #111827; font-weight: 700;">Chat with our AI to find your perfect match</p>
    </td>
  </tr>
</table>

<table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 24px;">
  <tr>
    <td width="33%" style="padding: 12px; text-align: center;">
      <p style="margin: 0 0 4px; font-size: 22px; font-weight: 800; color: #111827;">20,000+</p>
      <p style="margin: 0; font-size: 12px; color: #9ca3af;">Vehicles</p>
    </td>
    <td width="33%" style="padding: 12px; text-align: center;">
      <p style="margin: 0 0 4px; font-size: 22px; font-weight: 800; color: #111827;">&lt; 10 min</p>
      <p style="margin: 0; font-size: 12px; color: #9ca3af;">To complete</p>
    </td>
    <td width="33%" style="padding: 12px; text-align: center;">
      <p style="margin: 0 0 4px; font-size: 22px; font-weight: 800; color: #111827;">7 days</p>
      <p style="margin: 0; font-size: 12px; color: #9ca3af;">Money-back</p>
    </td>
  </tr>
</table>

<a href="<%= ENV.fetch('FRONTEND_URL', 'http://localhost:4200') %>" style="display: block; background-color: #00aed9; color: #ffffff; text-align: center; padding: 14px 24px; border-radius: 12px; text-decoration: none; font-weight: 700; font-size: 15px;">
  Start Browsing
</a>
